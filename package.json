{
  "name": "@vybra/passport",
  "version": "1.0.0",
  "description": "Shared Vybra passport utilities for identity payloads, avatars, QR codes, and cross-surface links.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
