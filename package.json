  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.0.0"
  }
}
